---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import { altLangUrl, type Lang } from '../i18n/ui';
import { SITE } from '../consts';

interface Props { lang: Lang; title: string; description?: string; }
const { lang, title, description = '' } = Astro.props;
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const fullTitle = title ? `${title} — ${SITE.name}` : SITE.name;
const ruHref = SITE.domain + altLangUrl(path, 'ru');
const enHref = SITE.domain + altLangUrl(path, 'en');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE.domain + path} />
    <meta property="og:image" content={SITE.domain + "/og.png"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:image" content={SITE.domain + "/og.png"} />
    <link rel="alternate" type="application/rss+xml" title="Khondamir Begmatov — Blog" href={lang === "en" ? "/en/rss.xml" : "/rss.xml"} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" hreflang="ru" href={ruHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={ruHref} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href={import.meta.env.BASE_URL.replace(/\/$/, "") + "/favicon.svg"} type="image/svg+xml" />
    <Analytics />
  </head>
  <body>
    <a href="#main" class="skip-link">{lang === 'ru' ? '\u041a \u0441\u043e\u0434\u0435\u0440\u0436\u0438\u043c\u043e\u043c\u0443' : 'Skip to content'}</a>
    <div class="site-video" aria-hidden="true">
      <video autoplay muted loop playsinline preload="auto" poster="/hero-poster.jpg">
        <source src="/hero-bg.mp4" type="video/mp4" />
      </video>
    </div>
    <Header lang={lang} path={path} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      (function () {
        const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
        function run() {
          if (mq.matches) return;
          const sel = '.section .feature, .posts-grid > *, .post-row, .case-section, .stat-row, .section-head, .article .prose, .contact-form';
          const els = Array.from(document.querySelectorAll(sel));
          const io = new IntersectionObserver((entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); }
            }
          }, { threshold: 0.08, rootMargin: '0px 0px -8% 0px' });
          for (const el of els) {
            const top = el.getBoundingClientRect().top;
            if (top < window.innerHeight * 0.92) { el.classList.add('is-visible'); continue; }
            el.classList.add('reveal-init');
            io.observe(el);
          }
        }
        if (document.readyState !== 'loading') run();
        else document.addEventListener('DOMContentLoaded', run);
        document.addEventListener('astro:page-load', run);
      })();
    </script>
  </body>
</html>
