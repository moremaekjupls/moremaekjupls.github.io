---
// Particle constellation (DESIGN.md / Dala).
//  variant="sphere" → rotating 3D globe of triangles
//  variant="earth"  → rotating globe with continents (land bright, ocean faint)
//  variant="glyph"  → a letter formed from particles (set `letter`)
// Depth, palette, cursor parallax, scroll dispersion. Honors reduced-motion.
interface Props {
  variant?: 'sphere' | 'earth' | 'glyph' | 'galaxy' | 'apple';
  letter?: string;
  density?: number;
  class?: string;
}
const { variant = 'sphere', letter = 'N', density = 1, class: className = '' } = Astro.props;
---
<canvas
  class={`particles js-particles ${className}`}
  data-variant={variant}
  data-letter={letter}
  data-density={density}
  aria-hidden="true"
></canvas>

<script>
  const PALETTE = ['#8052ff', '#8052ff', '#8052ff', '#ffffff', '#ffffff', '#bdbdbd', '#ffb829', '#15846e'];
  const LAND = ['#ffffff', '#ffffff', '#bdbdbd', '#15846e', '#ffb829'];
  const OCEAN = ['#8052ff', '#8052ff', '#5a5a8c'];
  const GA = Math.PI * (3 - Math.sqrt(5));
  const rand = (a: number, b: number) => a + Math.random() * (b - a);
  const clamp = (v: number, a: number, b: number) => (v < a ? a : v > b ? b : v);
  const pickFrom = (arr: string[]) => arr[(Math.random() * arr.length) | 0];

  function tri(ctx: CanvasRenderingContext2D, x: number, y: number, s: number, ang: number, fill: boolean) {
    ctx.beginPath();
    for (let k = 0; k < 3; k++) {
      const a = ang + k * (Math.PI * 2 / 3) - Math.PI / 2;
      const px = x + Math.cos(a) * s, py = y + Math.sin(a) * s;
      k === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    }
    ctx.closePath();
    fill ? ctx.fill() : ctx.stroke();
  }

  function baseSpherePoint(i: number, n: number) {
    const y = 1 - (i / (n - 1)) * 2;
    const r = Math.sqrt(Math.max(0, 1 - y * y));
    const th = i * GA;
    return { ux: Math.cos(th) * r, uy: y, uz: Math.sin(th) * r };
  }

  function buildSphere(n: number) {
    const pts: any[] = [];
    for (let i = 0; i < n; i++) {
      const sa = Math.random() * Math.PI * 2;
      pts.push({
        ...baseSpherePoint(i, n), land: true, sax: Math.cos(sa), say: Math.sin(sa),
        size: rand(2.0, 5.4), color: pickFrom(PALETTE), ang: Math.random() * 6.28,
        spin: rand(-0.0006, 0.0006), fill: Math.random() < 0.18, tw: rand(0.6, 1), ph: Math.random() * 6.28,
      });
    }
    return pts;
  }

  function landMask() {
    const MW = 360, MH = 180;
    const c = document.createElement('canvas'); c.width = MW; c.height = MH;
    const o = c.getContext('2d')!;
    const X = (lon: number) => (lon + 180) / 360 * MW;
    const Y = (lat: number) => (90 - lat) / 180 * MH;
    const poly = (pts: number[][]) => { o.beginPath(); pts.forEach(([a, b], i) => i ? o.lineTo(X(a), Y(b)) : o.moveTo(X(a), Y(b))); o.closePath(); o.fill(); };
    const ell = (lon: number, lat: number, rlon: number, rlat: number) => { o.beginPath(); o.ellipse(X(lon), Y(lat), rlon / 360 * MW, rlat / 180 * MH, 0, 0, Math.PI * 2); o.fill(); };
    o.fillStyle = '#fff';
    poly([[-17, 15], [0, 30], [10, 36], [33, 32], [50, 12], [43, -12], [35, -34], [20, -35], [12, -18], [8, 4], [-8, 5], [-17, 15]]);
    ell(12, 50, 28, 12); poly([[5, 55], [12, 71], [28, 70], [30, 55]]);
    ell(95, 48, 58, 26); poly([[68, 8], [80, 30], [90, 22], [78, 8]]); ell(108, 18, 16, 12); ell(45, 30, 16, 12);
    poly([[-165, 62], [-140, 70], [-95, 72], [-62, 60], [-58, 46], [-80, 24], [-100, 16], [-120, 30], [-140, 55], [-165, 62]]);
    poly([[-100, 16], [-88, 14], [-78, 8], [-92, 12], [-100, 16]]);
    ell(-42, 72, 16, 10);
    poly([[-80, 10], [-60, 8], [-50, 0], [-35, -8], [-50, -30], [-70, -54], [-72, -30], [-80, -5], [-80, 10]]);
    ell(133, -25, 22, 13);
    o.fillRect(0, Y(-65), MW, MH - Y(-65));
    return { data: o.getImageData(0, 0, MW, MH).data, MW, MH };
  }

  function buildEarth(n: number) {
    const { data, MW, MH } = landMask();
    const isLand = (lat: number, lon: number) => {
      const mx = ((Math.round((lon + 180) / 360 * MW) % MW) + MW) % MW;
      const my = clamp(Math.round((90 - lat) / 180 * MH), 0, MH - 1);
      return data[(my * MW + mx) * 4 + 3] > 128;
    };
    const pts: any[] = [];
    for (let i = 0; i < n; i++) {
      const b = baseSpherePoint(i, n);
      const lat = Math.asin(clamp(b.uy, -1, 1)) * 180 / Math.PI;
      const lon = Math.atan2(b.uz, b.ux) * 180 / Math.PI;
      const land = isLand(lat, lon);
      if (!land && Math.random() > 0.34) continue;
      const sa = Math.random() * Math.PI * 2;
      pts.push({
        ...b, land, sax: Math.cos(sa), say: Math.sin(sa),
        size: land ? rand(2.4, 5.2) : rand(1.6, 3.2),
        color: pickFrom(land ? LAND : OCEAN), ang: Math.random() * 6.28,
        spin: rand(-0.0006, 0.0006), fill: land && Math.random() < 0.45, tw: rand(0.6, 1), ph: Math.random() * 6.28,
      });
    }
    return pts;
  }

  function buildGlyph(letter: string, n: number) {
    const MW = 300, MH = 300;
    const c = document.createElement('canvas'); c.width = MW; c.height = MH;
    const o = c.getContext('2d')!;
    o.fillStyle = '#fff';
    o.textAlign = 'center'; o.textBaseline = 'middle';
    o.font = `700 230px "Space Grotesk", system-ui, sans-serif`;
    o.fillText(letter || 'N', MW / 2, MH / 2 + 6);
    const data = o.getImageData(0, 0, MW, MH).data;
    const cand: number[][] = [];
    for (let y = 0; y < MH; y += 2) for (let x = 0; x < MW; x += 2) if (data[(y * MW + x) * 4 + 3] > 128) cand.push([x, y]);
    for (let i = cand.length - 1; i > 0; i--) { const j = (Math.random() * (i + 1)) | 0;[cand[i], cand[j]] = [cand[j], cand[i]]; }
    const take = Math.min(n, cand.length);
    const pts: any[] = [];
    for (let i = 0; i < take; i++) {
      const [x, y] = cand[i];
      const sa = Math.random() * Math.PI * 2;
      pts.push({
        nx: (x - MW / 2) / (MH / 2), ny: (y - MH / 2) / (MH / 2), depth: Math.random(),
        sax: Math.cos(sa), say: Math.sin(sa),
        size: rand(2.0, 4.6), color: pickFrom(PALETTE), ang: Math.random() * 6.28,
        spin: rand(-0.0006, 0.0006), fill: Math.random() < 0.2, tw: rand(0.6, 1), ph: Math.random() * 6.28, drift: rand(0.4, 1.6),
      });
    }
    return pts;
  }

  function appleMask() {
    const MW = 320, MH = 320, cx = 160, cy = 168;
    const c = document.createElement('canvas'); c.width = MW; c.height = MH;
    const o = c.getContext('2d')!;
    const ell = (x: number, y: number, rx: number, ry: number) => { o.beginPath(); o.ellipse(x, y, rx, ry, 0, 0, Math.PI * 2); o.fill(); };
    o.fillStyle = '#fff';
    ell(cx - 40, cy + 6, 80, 80); ell(cx + 40, cy + 6, 80, 80);      // two lobes
    ell(cx, cy + 31, 58, 61);                                       // body
    o.beginPath(); o.moveTo(cx - 12, cy + 86); o.lineTo(cx + 12, cy + 86); o.lineTo(cx, cy + 104); o.closePath(); o.fill();
    o.globalCompositeOperation = 'destination-out';
    ell(cx, cy - 88, 22, 30);                                       // top dimple
    ell(cx, cy + 102, 10, 10);                                      // bottom dimple
    o.globalCompositeOperation = 'source-over';
    o.strokeStyle = '#fff'; o.lineWidth = 12; o.lineCap = 'round';  // stem
    o.beginPath(); o.moveTo(cx + 1, cy - 66); o.lineTo(cx + 9, cy - 112); o.stroke();
    o.save(); o.translate(cx + 8, cy - 88); o.rotate(-25 * Math.PI / 180); o.translate(-(cx + 8), -(cy - 88));
    ell(cx + 35, cy - 88, 27, 16); o.restore();                    // leaf
    return { data: o.getImageData(0, 0, MW, MH).data, MW, MH };
  }

  function buildApple(n: number) {
    const APAL = ['#15846e', '#15846e', '#ffb829', '#ffb829', '#ffffff', '#ffffff', '#bdbdbd', '#8052ff'];
    const { data, MW, MH } = appleMask();
    const cand: number[][] = [];
    for (let y = 0; y < MH; y += 2) for (let x = 0; x < MW; x += 2) if (data[(y * MW + x) * 4 + 3] > 128) cand.push([x, y]);
    for (let i = cand.length - 1; i > 0; i--) { const j = (Math.random() * (i + 1)) | 0;[cand[i], cand[j]] = [cand[j], cand[i]]; }
    const take = Math.min(n, cand.length);
    const pts: any[] = [];
    for (let i = 0; i < take; i++) {
      const [x, y] = cand[i];
      pts.push({
        nx: (x - 160) / 160, ny: (y - 160) / 160,
        ox: (x - 160) / 160 + rand(-1.8, 1.8), oy: (y - 160) / 160 - rand(1.2, 3.5),
        depth: Math.random(), size: rand(2.0, 4.6), color: APAL[(Math.random() * APAL.length) | 0],
        ang: Math.random() * 6.28, spin: rand(-0.0006, 0.0006), fill: Math.random() < 0.2,
        tw: rand(0.6, 1), ph: Math.random() * 6.28, drift: rand(0.3, 1.2),
      });
    }
    return pts;
  }

  function gauss() {
    let u = 0, v = 0;
    while (u === 0) u = Math.random();
    while (v === 0) v = Math.random();
    return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
  }

  function buildGalaxy(n: number) {
    const CORE = ['#ffffff', '#ffe4aa', '#ffb829'];
    const ARM = ['#8052ff', '#8052ff', '#ffffff', '#bdbdbd', '#15846e'];
    const arms = 2, wind = 3.6;
    const pts: any[] = [];
    for (let i = 0; i < n; i++) {
      let x: number, y: number, z: number, core = false, rc: number;
      if (Math.random() < 0.20) {
        const rr = Math.abs(gauss()) * 0.14;
        const th = Math.random() * 6.283, ph = Math.random() * 6.283;
        x = rr * Math.cos(th) * Math.cos(ph); z = rr * Math.sin(th) * Math.cos(ph); y = rr * Math.sin(ph) * 0.6;
        core = true; rc = rr;
      } else {
        const r = Math.pow(Math.random(), 1.4);
        const arm = (Math.random() * arms) | 0;
        const ang = arm * (Math.PI * 2 / arms) + r * wind + gauss() * (0.18 + 0.5 * (1 - r));
        x = r * Math.cos(ang); z = r * Math.sin(ang); y = gauss() * (0.02 + 0.05 * (1 - r)); rc = r;
      }
      const sa = Math.random() * Math.PI * 2;
      const inner = rc < 0.16;
      pts.push({
        x, y, z, core, rc, sax: Math.cos(sa), say: Math.sin(sa),
        size: core ? rand(2.0, 4.2) : rand(1.6, 4.2),
        color: (core || inner ? CORE : ARM)[(Math.random() * (core || inner ? 3 : 5)) | 0],
        ang: Math.random() * 6.28, spin: rand(-0.0006, 0.0006), fill: Math.random() < 0.2,
        tw: rand(0.6, 1), ph: Math.random() * 6.28,
      });
    }
    return pts;
  }

  function initCanvas(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mode = (canvas.dataset.variant as string) || 'sphere';
    const letter = canvas.dataset.letter || 'N';
    const density = parseFloat(canvas.dataset.density || '1');
    const hero = canvas.closest('.hero') as HTMLElement | null;
    let w = 0, h = 0, cxs = 0, cys = 0, radius = 0, S = 0, pts: any[] = [];
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let raf = 0, running = false;
    const m = { x: 0, y: 0, tx: 0, ty: 0 };
    let scrollP = 0;

    function layout() {
      const rect = canvas.getBoundingClientRect();
      w = Math.max(1, rect.width); h = Math.max(1, rect.height);
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx!.lineWidth = 1;
      const narrow = w < 760;
      cxs = (mode === 'glyph' || narrow) ? w * 0.5 : w * 0.63;
      cys = h * 0.5;
      const area = w * h;
      if (mode === 'apple') {
        S = Math.min(h * 0.34, w * 0.34);
        cys = h * 0.42;
        pts = buildApple(Math.round(clamp(area / 360 * density, 500, 1500)));
      } else if (mode === 'glyph') {
        S = Math.min(h * 0.4, w * 0.36);
        pts = buildGlyph(letter, Math.round(clamp(area / 360 * density, 280, 1300)));
      } else if (mode === 'earth') {
        radius = Math.min(w, narrow ? h * 0.9 : h * 1.02) * (narrow ? 0.36 : 0.42);
        pts = buildEarth(Math.round(clamp(area / 430 * density, 700, 2400)));
      } else if (mode === 'galaxy') {
        radius = Math.min(w, narrow ? h * 0.9 : h * 1.02) * (narrow ? 0.4 : 0.46);
        pts = buildGalaxy(Math.round(clamp(area / 360 * density, 1200, 3200)));
      } else {
        radius = Math.min(w, narrow ? h * 0.9 : h * 1.02) * (narrow ? 0.36 : 0.42);
        pts = buildSphere(Math.round(clamp(area / 560 * density, 420, 1800)));
      }
    }

    function updateScroll() {
      if (!hero) return;
      const hb = hero.getBoundingClientRect();
      scrollP = clamp(-hb.top / (hb.height * 0.85), 0, 1);
    }

    function render3D(t: number, animate: boolean) {
      const ry = (animate ? t * 0.00016 : 0.7) + m.x * 0.6;
      const rx = -0.16 + m.y * 0.4;
      const ca = Math.cos(ry), sa = Math.sin(ry), cb = Math.cos(rx), sb = Math.sin(rx);
      const disp = scrollP, rad = radius * (1 + disp * 1.7), fade = 1 - disp * 0.85, fov = 2.4;
      for (const p of pts) {
        let x = p.ux * ca + p.uz * sa, z = -p.ux * sa + p.uz * ca;
        let y = p.uy * cb - z * sb; z = p.uy * sb + z * cb;
        const persp = fov / (fov - z);
        let sx = cxs + x * rad * persp, sy = cys + y * rad * persp;
        if (disp > 0) { sx += p.sax * disp * 220; sy += p.say * disp * 220; }
        const depth = (z + 1) / 2;
        const tw = animate ? 0.6 + 0.4 * Math.sin(t * 0.001 + p.ph) : 1;
        let s: number, a: number;
        if (p.land) { s = p.size * (0.5 + depth * 0.85) * persp * 0.7; a = (0.16 + depth * 0.84) * p.tw * tw * fade; }
        else { s = p.size * (0.4 + depth * 0.7) * persp * 0.6; a = (0.07 + depth * 0.42) * p.tw * tw * fade; }
        ctx!.globalAlpha = clamp(a, 0, 1);
        ctx!.strokeStyle = p.color; ctx!.fillStyle = p.color;
        if (animate) p.ang += p.spin * 16;
        tri(ctx!, sx, sy, s, p.ang, p.fill);
      }
    }

    function render2D(t: number, animate: boolean) {
      const disp = scrollP, fade = 1 - disp * 0.85;
      for (const p of pts) {
        const dx = animate ? Math.sin(t * 0.0004 + p.ph) * p.drift : 0;
        const dy = animate ? Math.cos(t * 0.00045 + p.ph * 1.2) * p.drift : 0;
        const par = p.depth * 16;
        let sx = cxs + p.nx * S + dx - m.x * par;
        let sy = cys + p.ny * S + dy - m.y * par;
        if (disp > 0) { sx += p.sax * disp * 200; sy += p.say * disp * 200; }
        const s = p.size * (0.5 + p.depth * 0.8);
        const tw = animate ? 0.6 + 0.4 * Math.sin(t * 0.001 + p.ph) : 1;
        ctx!.globalAlpha = clamp((0.2 + p.depth * 0.8) * p.tw * tw * fade, 0, 1);
        ctx!.strokeStyle = p.color; ctx!.fillStyle = p.color;
        if (animate) p.ang += p.spin * 16;
        tri(ctx!, sx, sy, s, p.ang, p.fill);
      }
    }

    function renderGalaxy(t: number, animate: boolean) {
      const spin = (animate ? t * 0.00007 : 0.3) + m.x * 0.5;
      const tilt = 1.12 + m.y * 0.22;
      const cs = Math.cos(spin), sn = Math.sin(spin), ct = Math.cos(tilt), st = Math.sin(tilt);
      const disp = scrollP, ex = 1 + disp * 1.6, fade = 1 - disp * 0.85, fov = 2.6;
      for (const p of pts) {
        const x2 = p.x * cs + p.z * sn, z2 = -p.x * sn + p.z * cs, y2 = p.y;
        const yy = y2 * ct - z2 * st, zz = y2 * st + z2 * ct;
        const persp = fov / (fov - zz);
        let sx = cxs + x2 * radius * persp * ex, sy = cys + yy * radius * persp * ex;
        if (disp > 0) { sx += p.sax * disp * 220; sy += p.say * disp * 220; }
        const dep = (zz + 1) / 2;
        const tw = animate ? 0.6 + 0.4 * Math.sin(t * 0.001 + p.ph) : 1;
        let s: number, a: number;
        if (p.core) { s = p.size * (0.6 + dep * 0.6); a = (0.45 + dep * 0.55) * p.tw * tw * fade; }
        else { s = p.size * (0.5 + dep * 0.7); a = (0.14 + dep * 0.66) * p.tw * tw * fade * (0.5 + 0.5 * (1 - p.rc)); }
        ctx!.globalAlpha = clamp(a, 0, 1);
        ctx!.strokeStyle = p.color; ctx!.fillStyle = p.color;
        if (animate) p.ang += p.spin * 16;
        tri(ctx!, sx, sy, s, p.ang, p.fill);
      }
    }

    function renderApple(t: number, animate: boolean) {
      const rect = canvas.getBoundingClientRect();
      const vh = window.innerHeight || 800;
      const a = clamp((vh * 0.92 - rect.top) / (vh * 0.5), 0, 1);
      const e = a * a * (3 - 2 * a);
      for (const p of pts) {
        const hx = cxs + p.nx * S, hy = cys + p.ny * S;
        const ox = cxs + p.ox * S, oy = cys + p.oy * S;
        const bx = ox + (hx - ox) * e, by = oy + (hy - oy) * e;
        const dx = animate ? Math.sin(t * 0.0004 + p.ph) * p.drift * e : 0;
        const dy = animate ? Math.cos(t * 0.00045 + p.ph * 1.2) * p.drift * e : 0;
        const par = p.depth * 14 * e;
        const sx = bx + dx - m.x * par, sy = by + dy - m.y * par;
        const s = p.size * (0.5 + p.depth * 0.8);
        const tw = animate ? 0.6 + 0.4 * Math.sin(t * 0.001 + p.ph) : 1;
        ctx!.globalAlpha = clamp((0.2 + p.depth * 0.8) * p.tw * tw * e, 0, 1);
        ctx!.strokeStyle = p.color; ctx!.fillStyle = p.color;
        if (animate) p.ang += p.spin * 16;
        tri(ctx!, sx, sy, s, p.ang, p.fill);
      }
    }

    function frame(t: number, animate: boolean) {
      ctx!.clearRect(0, 0, w, h);
      m.x += (m.tx - m.x) * 0.06; m.y += (m.ty - m.y) * 0.06;
      mode === 'apple' ? renderApple(t, animate) : mode === 'glyph' ? render2D(t, animate) : mode === 'galaxy' ? renderGalaxy(t, animate) : render3D(t, animate);
      ctx!.globalAlpha = 1;
      if (running) raf = requestAnimationFrame((tt) => frame(tt, true));
    }

    function start() { if (!running && !reduce) { running = true; raf = requestAnimationFrame((tt) => frame(tt, true)); } }
    function stop() { running = false; cancelAnimationFrame(raf); }

    layout(); updateScroll();
    if (reduce) frame(0, false);
    // rebuild glyph once webfont is ready (sharper letter)
    if (mode === 'glyph' && (document as any).fonts?.ready) {
      (document as any).fonts.ready.then(() => { layout(); if (reduce) frame(0, false); });
    }

    let rt: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(rt);
      rt = window.setTimeout(() => { stop(); layout(); updateScroll(); reduce ? frame(0, false) : start(); }, 160);
    });

    if (!reduce) {
      window.addEventListener('scroll', () => updateScroll(), { passive: true });
      window.addEventListener('pointermove', (e) => {
        m.tx = (e.clientX / window.innerWidth - 0.5) * 2;
        m.ty = (e.clientY / window.innerHeight - 0.5) * 2;
      }, { passive: true });
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) e.isIntersecting ? start() : stop();
      }, { threshold: 0 });
      io.observe(canvas);
    }
  }

  function boot() {
    document.querySelectorAll<HTMLCanvasElement>('canvas.js-particles').forEach((c) => {
      if (!(c as any)._init) { (c as any)._init = true; initCanvas(c); }
    });
  }
  if (document.readyState !== 'loading') boot();
  else document.addEventListener('DOMContentLoaded', boot);
  document.addEventListener('astro:page-load', boot);
</script>
