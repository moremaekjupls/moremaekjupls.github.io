---
// Particle constellation — rotating 3D sphere of triangles (DESIGN.md / Dala).
// Dense globe of outlined triangles with depth, palette color, cursor tilt,
// and scroll-driven dispersion (the sphere scatters as you scroll past the hero).
// Respects prefers-reduced-motion (calm static globe).
interface Props {
  variant?: 'sphere' | 'brain' | 'spore';
  density?: number;
  class?: string;
}
const { variant = 'sphere', density = 1, class: className = '' } = Astro.props;
---
<canvas
  class={`particles js-particles ${className}`}
  data-variant={variant}
  data-density={density}
  aria-hidden="true"
></canvas>

<script>
  interface P {
    ux: number; uy: number; uz: number;      // unit vector on the sphere
    sax: number; say: number;                // scatter direction (screen-space, for disperse)
    size: number; color: string; ang: number; spin: number; fill: boolean; tw: number; ph: number;
  }
  const PALETTE = ['#8052ff', '#8052ff', '#8052ff', '#ffffff', '#ffffff', '#bdbdbd', '#ffb829', '#15846e'];
  const GA = Math.PI * (3 - Math.sqrt(5)); // golden angle
  const rand = (a: number, b: number) => a + Math.random() * (b - a);
  const clamp = (v: number, a: number, b: number) => v < a ? a : v > b ? b : v;

  function build(n: number): P[] {
    const pts: P[] = [];
    for (let i = 0; i < n; i++) {
      const y = 1 - (i / (n - 1)) * 2;
      const r = Math.sqrt(Math.max(0, 1 - y * y));
      const th = i * GA;
      const ux = Math.cos(th) * r, uy = y, uz = Math.sin(th) * r;
      const sa = Math.random() * Math.PI * 2;
      pts.push({
        ux, uy, uz,
        sax: Math.cos(sa), say: Math.sin(sa),
        size: rand(2.0, 5.4),
        color: PALETTE[(Math.random() * PALETTE.length) | 0],
        ang: Math.random() * Math.PI * 2,
        spin: rand(-0.0006, 0.0006),
        fill: Math.random() < 0.18,
        tw: rand(0.6, 1), ph: Math.random() * Math.PI * 2,
      });
    }
    return pts;
  }

  function tri(ctx: CanvasRenderingContext2D, x: number, y: number, s: number, ang: number, fill: boolean) {
    ctx.beginPath();
    for (let k = 0; k < 3; k++) {
      const a = ang + k * (Math.PI * 2 / 3) - Math.PI / 2;
      const px = x + Math.cos(a) * s, py = y + Math.sin(a) * s;
      k === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    }
    ctx.closePath();
    fill ? ctx.fill() : ctx.stroke();
  }

  function initCanvas(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const density = parseFloat(canvas.dataset.density || '1');
    const hero = canvas.closest('.hero') as HTMLElement | null;
    let w = 0, h = 0, cx = 0, cy = 0, radius = 0, pts: P[] = [];
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let raf = 0, running = false;
    const m = { x: 0, y: 0, tx: 0, ty: 0 };
    let scrollP = 0;

    function layout() {
      const rect = canvas.getBoundingClientRect();
      w = Math.max(1, rect.width); h = Math.max(1, rect.height);
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx!.lineWidth = 1;
      const narrow = w < 760;
      cx = narrow ? w * 0.5 : w * 0.62;
      cy = h * 0.5;
      radius = Math.min(w, narrow ? h * 0.9 : h * 1.02) * (narrow ? 0.36 : 0.42);
      const area = w * h;
      const n = Math.round(clamp(area / 560 * density, 420, 1800));
      pts = build(n);
    }

    function updateScroll() {
      if (!hero) return;
      const hb = hero.getBoundingClientRect();
      const past = clamp(-hb.top / (hb.height * 0.85), 0, 1);
      scrollP = past;
    }

    function render(t: number, animate: boolean) {
      ctx!.clearRect(0, 0, w, h);
      // eased pointer tilt
      m.x += (m.tx - m.x) * 0.06; m.y += (m.ty - m.y) * 0.06;
      const ry = (animate ? t * 0.00016 : 0.7) + m.x * 0.6;
      const rx = -0.12 + m.y * 0.4;
      const ca = Math.cos(ry), sa = Math.sin(ry), cb = Math.cos(rx), sb = Math.sin(rx);

      const disp = scrollP;                      // 0..1 dispersion
      const rad = radius * (1 + disp * 1.7);
      const fade = 1 - disp * 0.85;
      const fov = 2.4;

      for (const p of pts) {
        // rotate Y then X
        let x = p.ux * ca + p.uz * sa;
        let z = -p.ux * sa + p.uz * ca;
        let y = p.uy * cb - z * sb;
        z = p.uy * sb + z * cb;

        const persp = fov / (fov - z);            // depth scale (front bigger)
        let sx = cx + x * rad * persp;
        let sy = cy + y * rad * persp;
        // disperse outward along scatter dir
        if (disp > 0) { sx += p.sax * disp * 220; sy += p.say * disp * 220; }

        const depth = (z + 1) / 2;                // 0 back .. 1 front
        const s = p.size * (0.45 + depth * 0.85) * persp * 0.7;
        const tw = animate ? (0.6 + 0.4 * Math.sin(t * 0.001 + p.ph)) : 1;
        ctx!.globalAlpha = clamp((0.12 + depth * 0.9) * p.tw * tw * fade, 0, 1);
        ctx!.strokeStyle = p.color; ctx!.fillStyle = p.color;
        if (animate) p.ang += p.spin * 16;
        tri(ctx!, sx, sy, s, p.ang, p.fill);
      }
      ctx!.globalAlpha = 1;
      if (running) raf = requestAnimationFrame((tt) => render(tt, true));
    }

    function start() { if (!running && !reduce) { running = true; raf = requestAnimationFrame((tt) => render(tt, true)); } }
    function stop() { running = false; cancelAnimationFrame(raf); }

    layout(); updateScroll();
    reduce ? render(0, false) : null;

    let rt: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(rt);
      rt = window.setTimeout(() => { stop(); layout(); updateScroll(); reduce ? render(0, false) : start(); }, 160);
    });

    if (!reduce) {
      window.addEventListener('scroll', () => { updateScroll(); }, { passive: true });
      window.addEventListener('pointermove', (e) => {
        m.tx = (e.clientX / window.innerWidth - 0.5) * 2;
        m.ty = (e.clientY / window.innerHeight - 0.5) * 2;
      }, { passive: true });
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) e.isIntersecting ? start() : stop();
      }, { threshold: 0 });
      io.observe(canvas);
    }
  }

  function boot() {
    document.querySelectorAll<HTMLCanvasElement>('canvas.js-particles').forEach((c) => {
      if (!(c as any)._init) { (c as any)._init = true; initCanvas(c); }
    });
  }
  if (document.readyState !== 'loading') boot();
  else document.addEventListener('DOMContentLoaded', boot);
  document.addEventListener('astro:page-load', boot);
</script>
