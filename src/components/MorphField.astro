---
// Full-viewport particle field for the home page.
// Scroll-driven morph: galaxy → full-screen scatter → apple.
// Bigger, brighter, denser triangles. Honors prefers-reduced-motion.
---
<canvas class="morphfield js-morph" aria-hidden="true"></canvas>

<script>
  const PAL = ['#8052ff', '#8052ff', '#8052ff', '#ffffff', '#ffffff', '#bdbdbd', '#ffb829', '#15846e'];
  const APPLE_PAL = ['#15846e', '#15846e', '#ffb829', '#ffb829', '#ffffff', '#ffffff', '#bdbdbd', '#8052ff'];
  const GA = Math.PI * (3 - Math.sqrt(5));
  const rand = (a: number, b: number) => a + Math.random() * (b - a);
  const clamp = (v: number, a: number, b: number) => (v < a ? a : v > b ? b : v);
  const mix = (a: number, b: number, t: number) => a + (b - a) * t;
  const sstep = (e0: number, e1: number, x: number) => { const t = clamp((x - e0) / (e1 - e0), 0, 1); return t * t * (3 - 2 * t); };
  const pick = (arr: string[]) => arr[(Math.random() * arr.length) | 0];

  function tri(ctx: CanvasRenderingContext2D, x: number, y: number, s: number, ang: number, fill: boolean) {
    ctx.beginPath();
    for (let k = 0; k < 3; k++) {
      const a = ang + k * (Math.PI * 2 / 3) - Math.PI / 2;
      const px = x + Math.cos(a) * s, py = y + Math.sin(a) * s;
      k === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    }
    ctx.closePath();
    fill ? ctx.fill() : ctx.stroke();
  }

  function applePoints() {
    const MW = 320, MH = 320, cx = 160, cy = 168;
    const c = document.createElement('canvas'); c.width = MW; c.height = MH;
    const o = c.getContext('2d')!;
    const ell = (x: number, y: number, rx: number, ry: number) => { o.beginPath(); o.ellipse(x, y, rx, ry, 0, 0, Math.PI * 2); o.fill(); };
    o.fillStyle = '#fff';
    ell(cx - 40, cy + 6, 80, 80); ell(cx + 40, cy + 6, 80, 80); ell(cx, cy + 31, 58, 61);
    o.beginPath(); o.moveTo(cx - 12, cy + 86); o.lineTo(cx + 12, cy + 86); o.lineTo(cx, cy + 104); o.closePath(); o.fill();
    o.globalCompositeOperation = 'destination-out'; ell(cx, cy - 88, 22, 30); ell(cx, cy + 102, 10, 10);
    o.globalCompositeOperation = 'source-over';
    o.strokeStyle = '#fff'; o.lineWidth = 12; o.lineCap = 'round';
    o.beginPath(); o.moveTo(cx + 1, cy - 66); o.lineTo(cx + 9, cy - 112); o.stroke();
    o.save(); o.translate(cx + 8, cy - 88); o.rotate(-25 * Math.PI / 180); o.translate(-(cx + 8), -(cy - 88)); ell(cx + 35, cy - 88, 27, 16); o.restore();
    const d = o.getImageData(0, 0, MW, MH).data;
    const pool: number[][] = [];
    for (let y = 0; y < MH; y += 2) for (let x = 0; x < MW; x += 2) if (d[(y * MW + x) * 4 + 3] > 128) pool.push([(x - 160) / 160, (y - 160) / 160]);
    for (let i = pool.length - 1; i > 0; i--) { const j = (Math.random() * (i + 1)) | 0;[pool[i], pool[j]] = [pool[j], pool[i]]; }
    return pool;
  }

  function init(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0, pts: any[] = [], raf = 0, running = false;
    const m = { x: 0, y: 0, tx: 0, ty: 0 };

    function build() {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx!.lineWidth = 1.2;
      const narrow = w < 760;
      const n = Math.round(clamp((w * h) / 320, narrow ? 700 : 1600, narrow ? 1300 : 2800));
      const apple = applePoints();
      const arms = 2, wind = 3.6;
      pts = [];
      for (let i = 0; i < n; i++) {
        // galaxy disk coords
        let gx: number, gy: number, gz: number, core = false, rc: number;
        if (Math.random() < 0.2) {
          const rr = Math.abs(gaussian()) * 0.14, th = Math.random() * 6.283, ph = Math.random() * 6.283;
          gx = rr * Math.cos(th) * Math.cos(ph); gz = rr * Math.sin(th) * Math.cos(ph); gy = rr * Math.sin(ph) * 0.6; core = true; rc = rr;
        } else {
          const r = Math.pow(Math.random(), 1.4), arm = (Math.random() * arms) | 0;
          const ang = arm * (Math.PI * 2 / arms) + r * wind + gaussian() * (0.18 + 0.5 * (1 - r));
          gx = r * Math.cos(ang); gz = r * Math.sin(ang); gy = gaussian() * (0.02 + 0.05 * (1 - r)); rc = r;
        }
        const ap = apple[i % apple.length];
        pts.push({
          gx, gy, gz, core, rc, ax: ap[0], ay: ap[1],
          fx: Math.random(), fy: Math.random(),
          size: rand(3.0, 7.0), color: pick(PAL), acolor: pick(APPLE_PAL),
          ang: Math.random() * 6.28, spin: rand(-0.0006, 0.0006), fill: Math.random() < 0.22,
          tw: rand(0.6, 1), ph: Math.random() * 6.28,
        });
      }
    }

    function frame(t: number, animate: boolean) {
      ctx!.clearRect(0, 0, w, h);
      m.x += (m.tx - m.x) * 0.05; m.y += (m.ty - m.y) * 0.05;
      const vh = window.innerHeight || 800;
      const sf = (window.scrollY || 0) / vh;
      const m1 = sstep(0.12, 0.7, sf);   // galaxy -> scatter
      const m2 = sstep(0.82, 1.45, sf);  // scatter -> apple
      const m3 = sstep(1.75, 2.45, sf);  // apple -> scatter again

      const cx = w * 0.5, cy = h * 0.5;
      const gRadius = Math.min(w, h) * 0.42;
      const aS = Math.min(w, h) * 0.27;
      const spin = (animate ? t * 0.00006 : 0.3) + m.x * 0.4;
      const tilt = 1.12 + m.y * 0.2;
      const cs = Math.cos(spin), sn = Math.sin(spin), ct = Math.cos(tilt), st = Math.sin(tilt);
      const fov = 2.6;

      for (const p of pts) {
        // galaxy projected
        const x2 = p.gx * cs + p.gz * sn, z2 = -p.gx * sn + p.gz * cs, y2 = p.gy;
        const yy = y2 * ct - z2 * st, zz = y2 * st + z2 * ct;
        const persp = fov / (fov - zz);
        const gsx = cx + x2 * gRadius * persp, gsy = cy + yy * gRadius * persp;
        const gdep = (zz + 1) / 2;
        // apple + scatter targets
        const asx = cx + p.ax * aS, asy = cy + p.ay * aS;
        const ssx = p.fx * w, ssy = p.fy * h;
        // blend
        let px = mix(gsx, ssx, m1); px = mix(px, asx, m2); px = mix(px, ssx, m3);
        let py = mix(gsy, ssy, m1); py = mix(py, asy, m2); py = mix(py, ssy, m3);
        // parallax
        px -= m.x * 16 * (0.4 + gdep); py -= m.y * 16 * (0.4 + gdep);
        const tw = animate ? 0.6 + 0.4 * Math.sin(t * 0.001 + p.ph) : 1;
        const s = p.size * mix(0.55 + gdep * 0.7, 1.0, m1);
        const gA = 0.22 + gdep * 0.78;
        let al = mix(gA, 0.92, m1);
        al = mix(al, 0.95, m2 * 0.5);
        al *= (0.7 + 0.3 * tw);
        ctx!.globalAlpha = clamp(al, 0, 1);
        const col = m2 > 0.5 ? p.acolor : p.color;
        ctx!.strokeStyle = col; ctx!.fillStyle = col;
        if (animate) p.ang += p.spin * 16;
        tri(ctx!, px, py, s, p.ang, p.fill);
      }
      ctx!.globalAlpha = 1;
      if (running) raf = requestAnimationFrame((tt) => frame(tt, true));
    }

    function gaussian() {
      let u = 0, v = 0; while (u === 0) u = Math.random(); while (v === 0) v = Math.random();
      return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
    }
    function start() { if (!running && !reduce) { running = true; raf = requestAnimationFrame((tt) => frame(tt, true)); } }

    build();
    if (reduce) frame(0, false); else start();
    let rt: number | undefined;
    window.addEventListener('resize', () => { window.clearTimeout(rt); rt = window.setTimeout(() => { running = false; cancelAnimationFrame(raf); build(); reduce ? frame(0, false) : start(); }, 180); });
    if (!reduce) {
      window.addEventListener('scroll', () => {}, { passive: true });
      window.addEventListener('pointermove', (e) => { m.tx = (e.clientX / window.innerWidth - 0.5) * 2; m.ty = (e.clientY / window.innerHeight - 0.5) * 2; }, { passive: true });
    }
  }

  function boot() {
    const c = document.querySelector<HTMLCanvasElement>('canvas.js-morph');
    if (c && !(c as any)._init) { (c as any)._init = true; init(c); }
  }
  if (document.readyState !== 'loading') boot();
  else document.addEventListener('DOMContentLoaded', boot);
  document.addEventListener('astro:page-load', boot);
</script>
