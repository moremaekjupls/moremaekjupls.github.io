---
import Particles from '../Particles.astro';
import { useTranslations, type Lang } from '../../i18n/ui';
import { PROJECT } from '../../consts';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const sections = t('project.sections');
const stats = t('project.stats') as { num: string; label: string }[];
const titleParts = (t('project.tagline') as string);
const order = ['problem', 'what', 'how', 'result'] as const;
---
<!-- HEADER -->
<section class="hero" style="min-height:clamp(440px,60vh,560px);">
  <div class="hero-bg"><Particles variant="sphere" density={1.15} /></div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">{t('project.eyebrow')}</span>
      <h1 class="hero-title" style="font-size:clamp(64px,12vw,120px);">{t('project.title')}</h1>
      <p class="hero-sub">{titleParts}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={PROJECT.liveUrl} target={PROJECT.liveUrl === '#' ? undefined : '_blank'} rel="noopener noreferrer">{t('project.live')}</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true"></div>
  </div>
</section>

<!-- STATS -->
<section class="section">
  <div class="container">
    <div class="card stat-row">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-num">{s.num}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CASE SECTIONS -->
<section class="section">
  <div class="container">
    {order.map((key) => {
      const sec = sections[key];
      return (
        <div class="case-section">
          <div class="case-grid">
            <div class="case-label">{sec.label}</div>
            <div>
              <h2 class="heading" style="margin-bottom:18px;">{sec.heading}</h2>
              {sec.body.map((para: string) => (<p class="body body--muted" style="margin-bottom:14px;">{para}</p>))}
              {sec.bullets && (
                <ul style="margin-top:14px;padding-left:1.1em;color:var(--color-ash);">
                  {sec.bullets.map((b: string) => (<li style="margin-bottom:8px;">{b}</li>))}
                </ul>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>


<!-- LIVE CTA -->
<section class="section">
  <div class="container">
    <div class="card" style="text-align:center;padding:48px 24px;">
      <h2 class="heading-lg" style="margin-bottom:18px;">NURA</h2>
      <p class="body body--muted" style="margin:0 auto 24px;">{t('featured.desc')}</p>
      <a class="btn btn-primary" href={PROJECT.liveUrl} target={PROJECT.liveUrl === '#' ? undefined : '_blank'} rel="noopener noreferrer">{t('project.live')}</a>
    </div>
  </div>
</section>
