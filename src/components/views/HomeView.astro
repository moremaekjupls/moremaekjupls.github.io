---
import { getCollection } from 'astro:content';
import Particles from '../Particles.astro';
import PostCard from '../PostCard.astro';
import { useTranslations, localizeUrl, type Lang } from '../../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const L = (p: string) => localizeUrl(p, lang);

const posts = (await getCollection('blog', (e) => e.data.lang === lang && !e.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const titleLines = (t('hero.title') as string).split('\n');
---
<!-- HERO -->
<section class="hero">
  <div class="hero-bg"><Particles variant="earth" density={1.25} /></div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">{t('hero.eyebrow')}</span>
      <h1 class="hero-title">{titleLines.map((l, i) => (<>{l}{i < titleLines.length - 1 && <br />}</>))}</h1>
      <p class="hero-sub">{t('hero.sub')}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={L('/project')}>{t('cta.viewProject')}</a>
        <a class="btn btn-ghost" href={L('/blog')}>{t('cta.readBlog')}</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true"></div>
  </div>
  <div class="scroll-cue"><span class="dot"></span><span>Scroll</span></div>
</section>

<!-- FEATURED PROJECT -->
<section class="section">
  <div class="container">
    <div class="feature">
      <div>
        <span class="eyebrow">{t('featured.eyebrow')}</span>
        <h2 class="heading-lg">{t('featured.title')}</h2>
        <p class="subheading" style="color:var(--color-ash);margin-top:10px;">{t('featured.tagline')}</p>
        <p class="body body--muted" style="margin-top:18px;">{t('featured.desc')}</p>
        <div class="hero-cta" style="margin-top:24px;">
          <a class="btn btn-primary" href={L('/project')}>{t('cta.viewProject')}</a>
        </div>
      </div>
      <div class="feature-visual">
        <Particles variant="sphere" density={1} />
      </div>
    </div>
  </div>
</section>

<!-- LATEST POSTS -->
<section class="section">
  <div class="container">
    <div class="section-head">
      <div>
        <h2 class="heading">{t('latest.title')}</h2>
        <p class="muted" style="margin-top:6px;">{t('latest.subtitle')}</p>
      </div>
      <a class="link-arrow" href={L('/blog')}>{t('cta.allPosts')} →</a>
    </div>
    <div class="posts-grid">
      {posts.map((p) => (
        <PostCard lang={lang} title={p.data.title} excerpt={p.data.excerpt} date={p.data.pubDate} slug={p.data.transId} />
      ))}
    </div>
  </div>
</section>
