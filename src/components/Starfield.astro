---
// Site-wide cosmic backdrop: a faint twinkling starfield fixed behind all content.
// Honors prefers-reduced-motion (static stars).
---
<canvas class="starfield" id="starfield" aria-hidden="true"></canvas>

<script>
  function initStarfield() {
    const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
    if (!canvas || (canvas as any)._init) return;
    (canvas as any)._init = true;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const TINT = ['#ffffff', '#ffffff', '#ffffff', '#bdbdbd', '#8052ff', '#ffb829'];
    let w = 0, h = 0, stars: any[] = [], raf = 0;

    function build() {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      const n = Math.round(Math.min(620, (w * h) / 5400));
      stars = [];
      for (let i = 0; i < n; i++) {
        stars.push({
          x: Math.random() * w, y: Math.random() * h,
          r: Math.random() < 0.92 ? Math.random() * 0.9 + 0.3 : Math.random() * 1.6 + 1,
          base: Math.random() * 0.5 + 0.26,
          color: TINT[(Math.random() * TINT.length) | 0],
          sp: Math.random() * 0.0014 + 0.0004, ph: Math.random() * 6.28,
        });
      }
    }

    function draw(t: number) {
      ctx!.clearRect(0, 0, w, h);
      for (const s of stars) {
        const a = reduce ? s.base : s.base * (0.55 + 0.45 * Math.sin(t * s.sp + s.ph));
        ctx!.globalAlpha = a;
        ctx!.fillStyle = s.color;
        ctx!.beginPath();
        ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalAlpha = 1;
      if (!reduce) raf = requestAnimationFrame(draw);
    }

    build();
    if (reduce) draw(0); else raf = requestAnimationFrame(draw);
    let rt: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(rt);
      rt = window.setTimeout(() => { cancelAnimationFrame(raf); build(); reduce ? draw(0) : (raf = requestAnimationFrame(draw)); }, 200);
    });
  }
  if (document.readyState !== 'loading') initStarfield();
  else document.addEventListener('DOMContentLoaded', initStarfield);
  document.addEventListener('astro:page-load', initStarfield);
</script>
