---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostArticleView from '../../components/views/PostArticleView.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (e) => e.data.lang === 'ru' && !e.data.draft);
  return posts.map((entry) => ({ params: { slug: entry.data.transId }, props: { entry } }));
}
const { entry } = Astro.props;
---
<Base lang="ru" fixedBg title={entry.data.title} description={entry.data.excerpt}>
  <PostArticleView lang="ru" entry={entry} />
</Base>
